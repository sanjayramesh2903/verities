# LLM — Groq (free, no credit card: https://console.groq.com)
GROQ_API_KEY=gsk_...

PORT=3001

# Database (SQLite for dev, Supabase Postgres for prod)
DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Cache (optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# Search — Brave Search API (optional, falls back to DuckDuckGo)
# Free tier: 2,000 queries/month — https://api.search.brave.com
# BRAVE_API_KEY=BSA...

# Google OAuth (optional, enables login)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# JWT (auto-generated if not set; REQUIRED in production)
# JWT_SECRET=your-secret-here
# JWT_EXPIRY=7d

# Billing — Stripe (optional, enables paid tier)
# Get keys at dashboard.stripe.com
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# Email — Resend (optional, enables transactional emails)
# Free tier: 100 emails/day — https://resend.com
# RESEND_API_KEY=re_...

# Monitoring — Sentry (optional, enables error tracking)
# Free tier at https://sentry.io
# SENTRY_DSN=https://...@sentry.io/...

# Features
CONTENT_FILTER_ENABLED=true
FRONTEND_URL=http://localhost:5173
